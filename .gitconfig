[user]
    excludesfile = ~/.gitignore
	editor = nvim
	ignorecase = false
    name = emiravan
    email =

[init]
    defaultBranch = main

[hub]
  protocol = https

[github]
	user = emiravan

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    line-numbers = true
    navigate = true
    side-by-side=true
    syntax-theme = Solarized (dark)

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
